    },
    "node_modules/@brieftify/mock-engine": {
      "resolved": "packages/mock-engine",
      "link": true
    },
    "node_modules/contract-review-example": {
      "resolved": "examples/contract-review",
      "link": true
    },
    "node_modules/node-basic-example": {
      "resolved": "examples/node-basic",
      "link": true
    },
    "node_modules/typescript": {
      "version": "5.9.3",
      "resolved": "https://registry.npmjs.org/typescript/-/typescript-5.9.3.tgz",
      "integrity": "sha512-jl1vZzPDinLr9eUt3J/t7V6FgNEw9QjvBPdysz9KfQDD41fQrC2Y4vKQdiaUpFT4bXlb1RHhLpp8wtm6M5TgSw==",
      "dev": true,
      "license": "Apache-2.0",
      "bin": {
        "tsc": "bin/tsc",
        "tsserver": "bin/tsserver"
      },
      "engines": {
        "node": ">=14.17"
      }
    },
    "packages/contracts": {
      "name": "@brieftify/contracts",
      "version": "0.0.0-private",
