      "workspaces": [
        "packages/*",
        "examples/*"
      ],
      "devDependencies": {
        "typescript": "^5.7.2"
      }
    },
    "examples/contract-review": {
      "name": "contract-review-example"
    },
    "examples/node-basic": {
      "name": "node-basic-example"
    },
    "node_modules/@brieftify/contracts": {
      "resolved": "packages/contracts",
